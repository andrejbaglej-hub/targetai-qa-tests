{
  "name": "targetai-client-js-sdk",
  "version": "1.0.5",
  "description": "JavaScript SDK for TargetAI WebRTC voice agent communication",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "demo",
    "README.md",
    "QUICK_START.md",
    "TESTING.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "node test/test.js",
    "demo-server": "node test-server.js",
    "demo": "npm run build && npm run demo-server",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "webrtc",
    "voice",
    "ai",
    "agent",
    "targetai",
    "sdk"
  ],
  "author": "TargetAI",
  "license": "ISC",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.5",
    "rollup": "^4.9.6",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  }
}
